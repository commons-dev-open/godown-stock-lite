{
  "name": "godown-stock-lite",
  "version": "0.0.3",
  "description": "Godown Stock Management Desktop App",
  "main": "dist/main/index.js",
  "packageManager": "npm@10.9.4",
  "scripts": {
    "postinstall": "node scripts/native-better-sqlite3-for-electron.mjs rebuild",
    "predev": "node scripts/native-better-sqlite3-for-electron.mjs ensure",
    "prestart": "node scripts/native-better-sqlite3-for-electron.mjs ensure",
    "rebuild:native": "node scripts/native-better-sqlite3-for-electron.mjs rebuild",
    "dev": "npm run build:main && concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .",
    "db:clean": "node scripts/clean-db.mjs",
    "db:seed-dummy": "npm run build:main && cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/seed-dummy-data.mjs",
    "db:enrich-templates": "npm run build:main && cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/enrich-from-templates.mjs",
    "dev:fresh": "npm run db:clean && npm run dev",
    "prebuild": "node scripts/write-build-config.mjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:trial": "cross-env TRIAL_MODE=true npm run build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Arindam Hazra",
  "license": "MIT",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "volta": {
    "node": "22.21.1",
    "npm": "10.9.4"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.18",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.6.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^26.0.5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.godown.stock.lite",
    "productName": "Godown Stock Lite",
    "publish": "github",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "resources/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "resources/Icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
